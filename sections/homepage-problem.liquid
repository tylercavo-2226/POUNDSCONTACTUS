{%- comment -%}
  sections/homepage-problem.liquid
  Pounds Transformation — Problem Section v2
  Light gray bg, white stat cards with shadow
{%- endcomment -%}

<style>
  .pt-problem {
    background: #f7f8f7;
    padding: 100px var(--pt-px);
  }
  .pt-problem__inner {
    max-width: var(--pt-max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: center;
  }

  /* Scroll reveal */
  .pt-reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.65s ease, transform 0.65s ease;
  }
  .pt-reveal.visible { opacity: 1; transform: translateY(0); }
  .pt-reveal:nth-child(2) { transition-delay: 0.12s; }
  .pt-reveal:nth-child(3) { transition-delay: 0.22s; }

  /* Stat cards */
  .pt-problem__stats {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .pt-stat-card {
    background: #fff;
    border: 1px solid #e8ebe4;
    border-radius: 12px;
    padding: 24px 26px;
    display: flex;
    align-items: flex-start;
    gap: 20px;
    box-shadow: 0 2px 12px rgba(45,56,27,0.05);
    transition: box-shadow 0.2s;
  }
  .pt-stat-card:hover { box-shadow: 0 4px 20px rgba(45,56,27,0.09); }
  .pt-stat-card__num {
    font-family: var(--pt-font-body);
    font-size: clamp(40px, 4.5vw, 56px);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--pt-coral);
    flex-shrink: 0;
    min-width: 76px;
  }
  .pt-stat-card__num sup {
    font-size: 0.45em;
    vertical-align: super;
    letter-spacing: 0;
  }
  .pt-stat-card__label {
    font-family: var(--pt-font-body);
    font-size: 15px;
    font-weight: 700;
    color: var(--pt-green);
    margin-bottom: 5px;
    line-height: 1.3;
  }
  .pt-stat-card__desc {
    font-family: var(--pt-font-body);
    font-size: 13px;
    line-height: 1.65;
    color: var(--pt-muted);
  }

  @media (max-width: 900px) {
    .pt-problem { padding: 70px 20px; }
    .pt-problem__inner { grid-template-columns: 1fr; gap: 48px; }
  }
</style>

<section class="pt-problem" id="pt-problem">
  <div class="pt-problem__inner">

    <div class="pt-problem__copy pt-reveal">
      <div class="pt-section-eyebrow">Why Diets Fail</div>
      <h2 class="pt-section-heading">{{ section.settings.heading | default: 'You&rsquo;re Not Failing Your Diet. Your Diet Is Failing You.' }}</h2>
      <p class="pt-section-body">
        {{ section.settings.body_1 | default: 'Many of our patients arrive eating very little and exercising plenty &mdash; and still not losing weight. That&rsquo;s not a willpower problem. That&rsquo;s a biology problem.' }}
      </p>
      <p class="pt-section-body" style="margin-top:12px;">
        {{ section.settings.body_2 | default: 'Chronic stress triggers cortisol, which controls where fat gets stored, drives sugar cravings, and suppresses the thyroid hormones that regulate your metabolism. Most weight loss programs never test for it, let alone treat it.' }}
      </p>
    </div>

    <div class="pt-problem__stats">
      <div class="pt-stat-card pt-reveal">
        <div class="pt-stat-card__num">3<sup>×</sup></div>
        <div>
          <div class="pt-stat-card__label">More Abdominal Fat</div>
          <div class="pt-stat-card__desc">Elevated cortisol causes the body to preferentially store fat in the midsection, making belly fat resistant to exercise.</div>
        </div>
      </div>
      <div class="pt-stat-card pt-reveal">
        <div class="pt-stat-card__num">73<sup>%</sup></div>
        <div>
          <div class="pt-stat-card__label">of Cravings Are Stress-Driven</div>
          <div class="pt-stat-card__desc">Cortisol spikes trigger cravings for sugar and fat &mdash; sabotaging even the most disciplined eating plan.</div>
        </div>
      </div>
      <div class="pt-stat-card pt-reveal">
        <div class="pt-stat-card__num">40<sup>%</sup></div>
        <div>
          <div class="pt-stat-card__label">Metabolic Slowdown</div>
          <div class="pt-stat-card__desc">High cortisol suppresses thyroid function, slowing your resting metabolism by up to 40% &mdash; making every calorie count against you.</div>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
(function () {
  var els = document.querySelectorAll('#pt-problem .pt-reveal');
  if (!('IntersectionObserver' in window)) {
    els.forEach(function (el) { el.classList.add('visible'); });
    return;
  }
  var obs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
    });
  }, { threshold: 0.12 });
  els.forEach(function (el) { obs.observe(el); });
}());
</script>

{% schema %}
{
  "name": "Homepage: Problem",
  "tag": "div",
  "settings": [
    { "type": "text",     "id": "heading", "label": "Heading", "default": "You\u2019re Not Failing Your Diet. Your Diet Is Failing You." },
    { "type": "textarea", "id": "body_1",  "label": "Paragraph 1" },
    { "type": "textarea", "id": "body_2",  "label": "Paragraph 2" }
  ],
  "presets": [{ "name": "Homepage: Problem" }]
}
{% endschema %}
