{%- comment -%}
  sections/homepage-approach.liquid
  Pounds Transformation — Our Approach Section v2
  White bg, clean white cards with soft shadow
{%- endcomment -%}

<style>
  .pt-approach {
    background: #fff;
    padding: 100px var(--pt-px);
  }
  .pt-approach__inner {
    max-width: var(--pt-max-w);
    margin: 0 auto;
  }
  .pt-approach__header {
    text-align: center;
    max-width: 620px;
    margin: 0 auto 64px;
  }

  .pt-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    position: relative;
  }
  .pt-steps::before {
    content: '';
    position: absolute;
    top: 36px;
    left: calc(16.66% + 16px);
    right: calc(16.66% + 16px);
    height: 1px;
    background: linear-gradient(to right, #e8ebe4, var(--pt-coral), #e8ebe4);
    pointer-events: none;
  }

  .pt-step {
    background: #fff;
    border: 1px solid #e8ebe4;
    border-radius: 14px;
    padding: 32px 28px 28px;
    box-shadow: 0 2px 14px rgba(45,56,27,0.06);
    position: relative;
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease, box-shadow 0.2s;
  }
  .pt-step.visible { opacity: 1; transform: translateY(0); }
  .pt-step:nth-child(2) { transition-delay: 0.12s; }
  .pt-step:nth-child(3) { transition-delay: 0.24s; }
  .pt-step:hover { box-shadow: 0 6px 24px rgba(45,56,27,0.1); }

  .pt-step__num {
    width: 40px;
    height: 40px;
    background: var(--pt-coral);
    color: #fff;
    font-family: var(--pt-font-body);
    font-size: 16px;
    font-weight: 800;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    position: relative;
    z-index: 1;
  }
  .pt-step__title {
    font-family: var(--pt-font-body);
    font-size: 17px;
    font-weight: 800;
    color: var(--pt-green);
    margin-bottom: 10px;
    letter-spacing: -0.02em;
    line-height: 1.25;
  }
  .pt-step__body {
    font-family: var(--pt-font-body);
    font-size: 14px;
    line-height: 1.7;
    color: var(--pt-muted);
  }

  .pt-approach__cta {
    text-align: center;
    margin-top: 52px;
  }
  .pt-link-arrow {
    font-family: var(--pt-font-body);
    font-size: 14px;
    font-weight: 700;
    color: var(--pt-green-mid);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    border-bottom: 1.5px solid #d6ddd0;
    padding-bottom: 2px;
    transition: color 0.15s, border-color 0.15s;
  }
  .pt-link-arrow:hover { color: var(--pt-coral); border-color: var(--pt-coral); }

  @media (max-width: 900px) {
    .pt-approach { padding: 70px 20px; }
    .pt-steps { grid-template-columns: 1fr; gap: 16px; }
    .pt-steps::before { display: none; }
    .pt-approach__header { margin-bottom: 40px; }
  }
</style>

<section class="pt-approach" id="pt-approach">
  <div class="pt-approach__inner">

    <div class="pt-approach__header">
      <div class="pt-section-eyebrow">Our Method</div>
      <h2 class="pt-section-heading">{{ section.settings.heading | default: 'Root-Cause Medicine, Not a Quick Fix' }}</h2>
      <p class="pt-section-body">{{ section.settings.subheading | default: 'We don&rsquo;t prescribe a plan before we understand your biology. Every patient starts with a comprehensive metabolic workup.' }}</p>
    </div>

    <div class="pt-steps">
      <div class="pt-step" id="pt-step-1">
        <div class="pt-step__num">1</div>
        <div class="pt-step__title">{{ section.settings.step1_title | default: 'Metabolic Bloodwork &amp; Hormonal Testing' }}</div>
        <div class="pt-step__body">{{ section.settings.step1_body | default: 'We run a comprehensive panel — cortisol, thyroid, insulin, sex hormones, and metabolic markers — to identify exactly what is preventing you from losing weight.' }}</div>
      </div>
      <div class="pt-step" id="pt-step-2">
        <div class="pt-step__num">2</div>
        <div class="pt-step__title">{{ section.settings.step2_title | default: 'Personalized Treatment Plan' }}</div>
        <div class="pt-step__body">{{ section.settings.step2_body | default: 'Dr. Cavo and Michelle build a plan around your specific results — which may include GLP-1 medications, hormone support, nutrition protocols, and targeted supplementation.' }}</div>
      </div>
      <div class="pt-step" id="pt-step-3">
        <div class="pt-step__num">3</div>
        <div class="pt-step__title">{{ section.settings.step3_title | default: 'Ongoing Care &amp; Physician-Formulated Supplements' }}</div>
        <div class="pt-step__body">{{ section.settings.step3_body | default: 'You&rsquo;re supported at every stage with follow-up visits, progress monitoring, and access to our physician-formulated supplement line — the same products we prescribe in clinic.' }}</div>
      </div>
    </div>

    <div class="pt-approach__cta">
      <a href="{{ section.settings.cta_url | default: '/pages/contact-us' }}" class="pt-link-arrow">
        {{ section.settings.cta_label | default: 'Book Your Free Consultation' }}
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
          <path d="M2 6.5h9M8 3l4 3.5-4 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<script>
(function () {
  var steps = [
    document.getElementById('pt-step-1'),
    document.getElementById('pt-step-2'),
    document.getElementById('pt-step-3')
  ].filter(Boolean);
  if (!('IntersectionObserver' in window)) {
    steps.forEach(function (el) { el.classList.add('visible'); });
    return;
  }
  var obs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
    });
  }, { threshold: 0.2 });
  steps.forEach(function (el) { obs.observe(el); });
}());
</script>

{% schema %}
{
  "name": "Homepage: Approach",
  "tag": "div",
  "settings": [
    { "type": "text",     "id": "heading",    "label": "Heading",    "default": "Root-Cause Medicine, Not a Quick Fix" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "text",     "id": "step1_title","label": "Step 1 title","default": "Metabolic Bloodwork & Hormonal Testing" },
    { "type": "textarea", "id": "step1_body", "label": "Step 1 body" },
    { "type": "text",     "id": "step2_title","label": "Step 2 title","default": "Personalized Treatment Plan" },
    { "type": "textarea", "id": "step2_body", "label": "Step 2 body" },
    { "type": "text",     "id": "step3_title","label": "Step 3 title","default": "Ongoing Care & Physician-Formulated Supplements" },
    { "type": "textarea", "id": "step3_body", "label": "Step 3 body" },
    { "type": "text",     "id": "cta_label",  "label": "CTA text",   "default": "Book Your Free Consultation" },
    { "type": "url",      "id": "cta_url",    "label": "CTA URL" }
  ],
  "presets": [{ "name": "Homepage: Approach" }]
}
{% endschema %}
