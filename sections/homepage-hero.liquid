{%- comment -%}
  sections/homepage-hero.liquid
  Pounds Transformation — Hero Section v3
  Full-bleed background video or image with text overlay.
{%- endcomment -%}

<style>
  .pt-hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--pt-green);
  }

  /* Background media layer */
  .pt-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .pt-hero__bg-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  .pt-hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* Dark gradient overlay for readability */
  .pt-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(
        to right,
        rgba(18, 26, 10, 0.72) 0%,
        rgba(18, 26, 10, 0.52) 50%,
        rgba(18, 26, 10, 0.25) 100%
      ),
      linear-gradient(
        to top,
        rgba(18, 26, 10, 0.5) 0%,
        transparent 40%
      );
  }

  /* Content layer */
  .pt-hero__inner {
    position: relative;
    z-index: 2;
    max-width: var(--pt-max-w);
    margin: 0 auto;
    padding: 100px var(--pt-px) 100px;
    width: 100%;
    display: flex;
    align-items: center;
  }

  .pt-hero__copy {
    max-width: 680px;
  }

  /* Eyebrow pill */
  .pt-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--pt-font-body);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.9);
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.25);
    padding: 6px 14px;
    border-radius: 20px;
    margin-bottom: 28px;
    backdrop-filter: blur(4px);
    opacity: 0;
    transform: translateY(14px);
    animation: pt-rise 0.7s ease forwards 0.1s;
  }
  .pt-hero__eyebrow-dot {
    width: 6px; height: 6px;
    background: var(--pt-coral);
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* Headline */
  .pt-hero__heading {
    font-family: var(--pt-font-body);
    font-size: clamp(38px, 5.5vw, 72px);
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.03em;
    color: #fff;
    margin-bottom: 22px;
    opacity: 0;
    transform: translateY(20px);
    animation: pt-rise 0.8s ease forwards 0.25s;
  }
  .pt-hero__heading em {
    font-style: italic;
    color: var(--pt-coral);
  }

  /* Subtext */
  .pt-hero__sub {
    font-family: var(--pt-font-body);
    font-size: clamp(16px, 1.6vw, 19px);
    line-height: 1.7;
    color: rgba(255,255,255,0.82);
    max-width: 560px;
    margin-bottom: 38px;
    opacity: 0;
    transform: translateY(18px);
    animation: pt-rise 0.8s ease forwards 0.42s;
  }

  /* CTA row */
  .pt-hero__actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 40px;
    opacity: 0;
    transform: translateY(16px);
    animation: pt-rise 0.8s ease forwards 0.56s;
  }
  .pt-btn-coral-lg {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--pt-font-body);
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    background: var(--pt-coral);
    text-decoration: none;
    padding: 16px 32px;
    border-radius: 6px;
    transition: background 0.15s, transform 0.12s, box-shadow 0.15s;
    box-shadow: 0 4px 22px rgba(226,109,92,0.45);
    letter-spacing: 0.01em;
  }
  .pt-btn-coral-lg:hover {
    background: var(--pt-coral-dk);
    transform: translateY(-2px);
    box-shadow: 0 6px 28px rgba(226,109,92,0.55);
  }
  .pt-btn-ghost-light {
    font-family: var(--pt-font-body);
    font-size: 14px;
    font-weight: 600;
    color: rgba(255,255,255,0.88);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border-bottom: 1.5px solid rgba(255,255,255,0.35);
    padding-bottom: 2px;
    transition: color 0.15s, border-color 0.15s;
  }
  .pt-btn-ghost-light:hover {
    color: #fff;
    border-color: rgba(255,255,255,0.7);
  }

  /* Trust badges */
  .pt-hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    opacity: 0;
    transform: translateY(14px);
    animation: pt-rise 0.8s ease forwards 0.72s;
  }
  .pt-trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--pt-font-body);
    font-size: 12px;
    font-weight: 600;
    color: rgba(255,255,255,0.88);
    background: rgba(255,255,255,0.10);
    border: 1px solid rgba(255,255,255,0.22);
    padding: 6px 12px;
    border-radius: 20px;
    white-space: nowrap;
    backdrop-filter: blur(4px);
  }
  .pt-trust-badge__check {
    color: var(--pt-coral);
    font-size: 12px;
    font-weight: 800;
  }

  /* Bottom scroll cue */
  .pt-hero__scroll-cue {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    opacity: 0;
    animation: pt-rise 1s ease forwards 1.2s;
  }
  .pt-hero__scroll-cue-label {
    font-family: var(--pt-font-body);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
  }
  .pt-hero__scroll-cue-line {
    width: 1px;
    height: 32px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.4), transparent);
    animation: pt-scroll-pulse 1.8s ease-in-out infinite;
  }
  @keyframes pt-scroll-pulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.15); }
  }

  @keyframes pt-rise {
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  @media (max-width: 900px) {
    .pt-hero { min-height: 80vh; }
    .pt-hero__inner { padding: 80px 20px 80px; }
    .pt-hero__overlay {
      background:
        linear-gradient(to bottom, rgba(18,26,10,0.55) 0%, rgba(18,26,10,0.7) 100%);
    }
    .pt-hero__copy { max-width: 100%; }
  }
  @media (max-width: 600px) {
    .pt-hero { min-height: 100svh; }
    .pt-hero__heading { font-size: 36px; }
    .pt-hero__sub { font-size: 16px; }
    .pt-hero__actions { flex-direction: column; align-items: flex-start; }
    .pt-btn-coral-lg { width: 100%; justify-content: center; }
    .pt-hero__scroll-cue { display: none; }
  }
</style>

<section class="pt-hero" id="pt-hero">

  <!-- Background media -->
  <div class="pt-hero__bg">
    {%- if section.settings.hero_video != blank -%}
      <video
        class="pt-hero__bg-video"
        src="{{ section.settings.hero_video }}"
        autoplay muted loop playsinline
        poster="{% if section.settings.hero_image != blank %}{{ section.settings.hero_image | img_url: '1600x900', crop: 'center' }}{% endif %}"
        aria-hidden="true">
      </video>
    {%- elsif section.settings.hero_image != blank -%}
      <img
        class="pt-hero__bg-img"
        src="{{ section.settings.hero_image | img_url: '1600x900', crop: 'center' }}"
        alt=""
        loading="eager"
        aria-hidden="true">
    {%- endif -%}
  </div>

  <!-- Gradient overlay -->
  <div class="pt-hero__overlay" aria-hidden="true"></div>

  <!-- Content -->
  <div class="pt-hero__inner">
    <div class="pt-hero__copy">

      <div class="pt-hero__eyebrow">
        <span class="pt-hero__eyebrow-dot"></span>
        {{ section.settings.eyebrow | default: 'Board-Certified Medical Weight Loss · Central CT' }}
      </div>

      <h1 class="pt-hero__heading">
        {{ section.settings.heading | default: 'We Find Out <em>Why</em> You Can&rsquo;t Lose Weight &mdash; Then We Treat the Cause' }}
      </h1>

      <p class="pt-hero__sub">
        {{ section.settings.subheading | default: 'Most programs tell you to eat less and exercise more. We run metabolic bloodwork, hormonal testing, and a root-cause diagnosis &mdash; then build a plan that actually works.' }}
      </p>

      <div class="pt-hero__actions">
        <a href="{{ section.settings.cta_primary_url | default: '/pages/contact-us' }}" class="pt-btn-coral-lg">
          {{ section.settings.cta_primary_label | default: 'Schedule Your Metabolic Assessment' }}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="{{ section.settings.cta_secondary_url | default: '/collections/all' }}" class="pt-btn-ghost-light">
          {{ section.settings.cta_secondary_label | default: 'Explore Our Supplements' }}
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <div class="pt-hero__trust">
        <span class="pt-trust-badge"><span class="pt-trust-badge__check">✓</span> Board-Certified Bariatric Physician</span>
        <span class="pt-trust-badge"><span class="pt-trust-badge__check">✓</span> Accepted by Most Insurers</span>
        <span class="pt-trust-badge"><span class="pt-trust-badge__check">✓</span> 13 Years in Practice</span>
        <span class="pt-trust-badge"><span class="pt-trust-badge__check">✓</span> 3 Connecticut Locations</span>
      </div>

    </div>
  </div>

  <!-- Scroll cue -->
  <div class="pt-hero__scroll-cue" aria-hidden="true">
    <span class="pt-hero__scroll-cue-label">Scroll</span>
    <span class="pt-hero__scroll-cue-line"></span>
  </div>

</section>

{% schema %}
{
  "name": "Homepage Hero",
  "tag": "div",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Background photo (fallback if no video)" },
    { "type": "text",         "id": "hero_video", "label": "Background video URL (.mp4) — paste CDN or Shopify Files URL" },
    { "type": "text",         "id": "eyebrow",             "label": "Eyebrow text",       "default": "Board-Certified Medical Weight Loss · West Hartford, CT" },
    { "type": "richtext",     "id": "heading",             "label": "Headline",           "default": "<p>We Find Out <em>Why</em> You Can\u2019t Lose Weight \u2014 Then We Treat the Cause</p>" },
    { "type": "textarea",     "id": "subheading",          "label": "Subheading",         "default": "Most programs tell you to eat less and exercise more. We run metabolic bloodwork, hormonal testing, and a root-cause diagnosis \u2014 then build a plan that actually works." },
    { "type": "text",         "id": "cta_primary_label",   "label": "Primary CTA text",   "default": "Schedule Your Metabolic Assessment" },
    { "type": "url",          "id": "cta_primary_url",     "label": "Primary CTA URL" },
    { "type": "text",         "id": "cta_secondary_label", "label": "Secondary CTA text", "default": "Explore Our Supplements" },
    { "type": "url",          "id": "cta_secondary_url",   "label": "Secondary CTA URL" }
  ],
  "presets": [{ "name": "Homepage Hero" }]
}
{% endschema %}
