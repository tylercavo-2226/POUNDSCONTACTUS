{%- comment -%}
  sections/homepage-testimonials.liquid
  Pounds Transformation — Patient Results Section v2
  Light gray bg, white cards with shadow
{%- endcomment -%}

<style>
  .pt-testimonials {
    background: #f7f8f7;
    padding: 100px var(--pt-px);
  }
  .pt-testimonials__inner {
    max-width: var(--pt-max-w);
    margin: 0 auto;
  }
  .pt-testimonials__header {
    text-align: center;
    max-width: 560px;
    margin: 0 auto 56px;
  }

  .pt-testi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 40px;
  }

  .pt-testi-card {
    background: #fff;
    border: 1px solid #e8ebe4;
    border-radius: 14px;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    box-shadow: 0 2px 12px rgba(45,56,27,0.05);
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.6s ease, transform 0.6s ease, box-shadow 0.2s;
  }
  .pt-testi-card.visible { opacity: 1; transform: translateY(0); }
  .pt-testi-card:nth-child(2) { transition-delay: 0.12s; }
  .pt-testi-card:nth-child(3) { transition-delay: 0.24s; }
  .pt-testi-card:hover { box-shadow: 0 6px 22px rgba(45,56,27,0.09); }

  /* Opening quote mark */
  .pt-testi-card__open-quote {
    font-family: Georgia, serif;
    font-size: 64px;
    line-height: 0.6;
    color: var(--pt-coral);
    opacity: 0.35;
    margin-bottom: 16px;
    display: block;
  }

  .pt-testi-card__outcome {
    font-family: var(--pt-font-body);
    font-size: 13px;
    font-weight: 700;
    color: var(--pt-green-mid);
    background: #f0f4ed;
    border: 1px solid #d6ddd0;
    border-radius: 20px;
    padding: 4px 12px;
    display: inline-block;
    margin-bottom: 16px;
  }
  .pt-testi-card__quote {
    font-family: var(--pt-font-body);
    font-size: 14px;
    line-height: 1.75;
    color: var(--pt-muted);
    flex: 1;
    margin-bottom: 24px;
  }
  .pt-testi-card__author {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-top: 18px;
    border-top: 1px solid #e8ebe4;
  }
  .pt-testi-card__avatar {
    width: 36px;
    height: 36px;
    background: var(--pt-green);
    color: #fff;
    font-family: var(--pt-font-body);
    font-size: 14px;
    font-weight: 700;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .pt-testi-card__stars {
    color: #f5a623;
    font-size: 13px;
    letter-spacing: 1px;
    margin-bottom: 2px;
  }
  .pt-testi-card__name {
    font-family: var(--pt-font-body);
    font-size: 13px;
    font-weight: 700;
    color: var(--pt-green);
  }
  .pt-testi-card__location {
    font-family: var(--pt-font-body);
    font-size: 11px;
    color: var(--pt-muted);
    margin-top: 1px;
  }

  /* Aggregate review bar */
  .pt-testi-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
    background: #fff;
    border: 1px solid #e8ebe4;
    border-radius: 12px;
    padding: 22px 36px;
    margin-bottom: 36px;
    box-shadow: 0 2px 10px rgba(45,56,27,0.04);
  }
  .pt-testi-bar__rating {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--pt-font-body);
    font-size: 15px;
    font-weight: 700;
    color: var(--pt-green);
  }
  .pt-testi-bar__stars { color: #f5a623; font-size: 20px; letter-spacing: 2px; }
  .pt-testi-bar__divider {
    width: 1px;
    height: 28px;
    background: #e8ebe4;
  }
  .pt-testi-bar__count {
    font-family: var(--pt-font-body);
    font-size: 13px;
    color: var(--pt-muted);
  }
  .pt-testi-bar__count strong { color: var(--pt-green); }

  .pt-testimonials__cta { text-align: center; }
  .pt-link-arrow {
    font-family: var(--pt-font-body);
    font-size: 14px;
    font-weight: 700;
    color: var(--pt-green-mid);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    border-bottom: 1.5px solid #d6ddd0;
    padding-bottom: 2px;
    transition: color 0.15s, border-color 0.15s;
  }
  .pt-link-arrow:hover { color: var(--pt-coral); border-color: var(--pt-coral); }

  @media (max-width: 900px) {
    .pt-testimonials { padding: 70px 20px; }
    .pt-testi-grid   { grid-template-columns: 1fr; gap: 14px; }
    .pt-testi-bar    { flex-direction: column; text-align: center; gap: 10px; }
    .pt-testi-bar__divider { width: 40px; height: 1px; }
  }
</style>

<section class="pt-testimonials" id="pt-testimonials">
  <div class="pt-testimonials__inner">

    <div class="pt-testimonials__header">
      <div class="pt-section-eyebrow">Patient Results</div>
      <h2 class="pt-section-heading">{{ section.settings.heading | default: 'Real People. Real Results.' }}</h2>
      <p class="pt-section-body">{{ section.settings.subheading | default: 'When you treat the cause &mdash; not just the symptom &mdash; the results follow.' }}</p>
    </div>

    <div class="pt-testi-grid">

      <div class="pt-testi-card" id="pt-testi-1">
        <span class="pt-testi-card__open-quote">&ldquo;</span>
        <div class="pt-testi-card__outcome">{{ section.settings.t1_outcome | default: 'Finally found what was actually wrong' }}</div>
        <div class="pt-testi-card__quote">{{ section.settings.t1_quote | default: 'I had been struggling for years. Michelle sat down with me, ran bloodwork no one had ever run before, and within weeks we had a real answer. I finally feel like myself again.' }}</div>
        <div class="pt-testi-card__author">
          <div class="pt-testi-card__avatar">{{ section.settings.t1_name | default: 'Amanda' | slice: 0 }}</div>
          <div>
            <div class="pt-testi-card__stars">★★★★★</div>
            <div class="pt-testi-card__name">{{ section.settings.t1_name | default: 'Amanda' }}</div>
            <div class="pt-testi-card__location">{{ section.settings.t1_location | default: 'West Hartford, CT' }}</div>
          </div>
        </div>
      </div>

      <div class="pt-testi-card" id="pt-testi-2">
        <span class="pt-testi-card__open-quote">&ldquo;</span>
        <div class="pt-testi-card__outcome">{{ section.settings.t2_outcome | default: 'Lost weight for the first time in years' }}</div>
        <div class="pt-testi-card__quote">{{ section.settings.t2_quote | default: 'I had tried every diet. What was different here was that they tested my hormones and metabolism first. Once we fixed those, the weight actually started coming off.' }}</div>
        <div class="pt-testi-card__author">
          <div class="pt-testi-card__avatar">{{ section.settings.t2_name | default: 'Angie' | slice: 0 }}</div>
          <div>
            <div class="pt-testi-card__stars">★★★★★</div>
            <div class="pt-testi-card__name">{{ section.settings.t2_name | default: 'Angie' }}</div>
            <div class="pt-testi-card__location">{{ section.settings.t2_location | default: 'Southington, CT' }}</div>
          </div>
        </div>
      </div>

      <div class="pt-testi-card" id="pt-testi-3">
        <span class="pt-testi-card__open-quote">&ldquo;</span>
        <div class="pt-testi-card__outcome">{{ section.settings.t3_outcome | default: 'Insurance covered my visits — a huge relief' }}</div>
        <div class="pt-testi-card__quote">{{ section.settings.t3_quote | default: 'I assumed medical weight loss would cost thousands out of pocket. When I found out my insurance covered my visits at Pounds, I was floored. The team is incredible.' }}</div>
        <div class="pt-testi-card__author">
          <div class="pt-testi-card__avatar">{{ section.settings.t3_name | default: 'Suzanne' | slice: 0 }}</div>
          <div>
            <div class="pt-testi-card__stars">★★★★★</div>
            <div class="pt-testi-card__name">{{ section.settings.t3_name | default: 'Suzanne' }}</div>
            <div class="pt-testi-card__location">{{ section.settings.t3_location | default: 'Glastonbury, CT' }}</div>
          </div>
        </div>
      </div>

    </div>

    <div class="pt-testi-bar">
      <div class="pt-testi-bar__rating">
        <span class="pt-testi-bar__stars">★★★★★</span>
        4.6 out of 5
      </div>
      <div class="pt-testi-bar__divider"></div>
      <div class="pt-testi-bar__count"><strong>72 verified reviews</strong> across Google &amp; Judge.me</div>
      <div class="pt-testi-bar__divider"></div>
      <div class="pt-testi-bar__count">In practice <strong>since 2013</strong></div>
    </div>

    <div class="pt-testimonials__cta">
      <a href="{{ section.settings.cta_url | default: '/pages/success-stories' }}" class="pt-link-arrow">
        {{ section.settings.cta_label | default: 'Read All Success Stories' }}
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
          <path d="M2 6.5h9M8 3l4 3.5-4 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<script>
(function () {
  var cards = [
    document.getElementById('pt-testi-1'),
    document.getElementById('pt-testi-2'),
    document.getElementById('pt-testi-3')
  ].filter(Boolean);
  if (!('IntersectionObserver' in window)) {
    cards.forEach(function (el) { el.classList.add('visible'); });
    return;
  }
  var obs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
    });
  }, { threshold: 0.12 });
  cards.forEach(function (el) { obs.observe(el); });
}());
</script>

{% schema %}
{
  "name": "Homepage: Testimonials",
  "tag": "div",
  "settings": [
    { "type": "text",     "id": "heading",     "label": "Heading",          "default": "Real People. Real Results." },
    { "type": "textarea", "id": "subheading",  "label": "Subheading" },
    { "type": "text",     "id": "t1_outcome",  "label": "Testimonial 1: Outcome tag" },
    { "type": "textarea", "id": "t1_quote",    "label": "Testimonial 1: Quote" },
    { "type": "text",     "id": "t1_name",     "label": "Testimonial 1: Name",     "default": "Amanda" },
    { "type": "text",     "id": "t1_location", "label": "Testimonial 1: Location", "default": "West Hartford, CT" },
    { "type": "text",     "id": "t2_outcome",  "label": "Testimonial 2: Outcome tag" },
    { "type": "textarea", "id": "t2_quote",    "label": "Testimonial 2: Quote" },
    { "type": "text",     "id": "t2_name",     "label": "Testimonial 2: Name",     "default": "Angie" },
    { "type": "text",     "id": "t2_location", "label": "Testimonial 2: Location", "default": "Southington, CT" },
    { "type": "text",     "id": "t3_outcome",  "label": "Testimonial 3: Outcome tag" },
    { "type": "textarea", "id": "t3_quote",    "label": "Testimonial 3: Quote" },
    { "type": "text",     "id": "t3_name",     "label": "Testimonial 3: Name",     "default": "Suzanne" },
    { "type": "text",     "id": "t3_location", "label": "Testimonial 3: Location", "default": "Glastonbury, CT" },
    { "type": "text",     "id": "cta_label",   "label": "CTA text", "default": "Read All Success Stories" },
    { "type": "url",      "id": "cta_url",     "label": "CTA URL" }
  ],
  "presets": [{ "name": "Homepage: Testimonials" }]
}
{% endschema %}
