        Southington <a href="tel:8605178888">(860) 517-8888</a> &middot;
        Glastonbury <a href="tel:8604942400">(860) 494-2400</a>
      </div>

    </div>
  </div>
</section>

<script>
(function () {
  /* ── Scroll-fade ─────────────────────────────────────────── */
  var fadeEls = Array.prototype.slice.call(document.querySelectorAll('.pt-cp-fade'));
  if ('IntersectionObserver' in window) {
    var fadeObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('visible'); fadeObs.unobserve(e.target); }
      });
    }, { threshold: 0.1 });
    fadeEls.forEach(function (el) { fadeObs.observe(el); });
  } else {
    fadeEls.forEach(function (el) { el.classList.add('visible'); });
  }

  /* ── Testimonial cards ───────────────────────────────────── */
  var cards = [
    document.getElementById('pt-cp-proof-1'),
    document.getElementById('pt-cp-proof-2'),
    document.getElementById('pt-cp-proof-3')
  ].filter(Boolean);
  if ('IntersectionObserver' in window && cards.length) {
    var cardObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('visible'); cardObs.unobserve(e.target); }
      });
    }, { threshold: 0.12 });
    cards.forEach(function (el) { cardObs.observe(el); });
  } else {
    cards.forEach(function (el) { el.classList.add('visible'); });
  }

  /* ── First visit steps ───────────────────────────────────── */
  var vsteps = [
    document.getElementById('pt-cp-vstep-1'),
    document.getElementById('pt-cp-vstep-2'),
    document.getElementById('pt-cp-vstep-3')
  ].filter(Boolean);
  if ('IntersectionObserver' in window && vsteps.length) {
    var stepObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('visible'); stepObs.unobserve(e.target); }
      });
    }, { threshold: 0.15 });
    vsteps.forEach(function (el) { stepObs.observe(el); });
  } else {
    vsteps.forEach(function (el) { el.classList.add('visible'); });
  }

  /* ── FAQ accordion ───────────────────────────────────────── */
  var faqList = document.getElementById('pt-cp-faq-list');
  if (faqList) {
    faqList.addEventListener('click', function (e) {
      var trigger = e.target.closest('.pt-cp-faq__trigger');
      if (!trigger) return;
      var item = trigger.closest('.pt-cp-faq__item');
      var isOpen = item.classList.contains('open');
      faqList.querySelectorAll('.pt-cp-faq__item').forEach(function (el) {
        el.classList.remove('open');
        el.querySelector('.pt-cp-faq__trigger').setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.classList.add('open');
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  }

  /* ── Smooth scroll (nav CTA → hero form) ────────────────── */
  document.querySelectorAll('a[href="#pt-cp-form"]').forEach(function (link) {
    link.addEventListener('click', function (e) {
      e.preventDefault();
      var target = document.getElementById('pt-cp-hero-form-card') || document.getElementById('pt-cp-form');
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
}());
</script>

