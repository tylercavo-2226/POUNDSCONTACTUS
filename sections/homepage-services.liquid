{%- comment -%}
  sections/homepage-services.liquid
  Pounds Transformation — Services Overview Section v2
  White bg, clean white cards with inline SVG icons
{%- endcomment -%}

<style>
  .pt-services {
    background: #fff;
    padding: 100px var(--pt-px);
  }
  .pt-services__inner {
    max-width: var(--pt-max-w);
    margin: 0 auto;
  }
  .pt-services__header {
    text-align: center;
    max-width: 560px;
    margin: 0 auto 56px;
  }

  .pt-svc-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .pt-svc-card {
    background: #fff;
    border: 1px solid #e8ebe4;
    border-radius: 14px;
    padding: 36px 32px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    box-shadow: 0 2px 12px rgba(45,56,27,0.05);
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.55s ease, transform 0.55s ease, box-shadow 0.2s, border-color 0.2s;
  }
  .pt-svc-card.visible   { opacity: 1; transform: translateY(0); }
  .pt-svc-card:nth-child(2) { transition-delay: 0.1s; }
  .pt-svc-card:nth-child(3) { transition-delay: 0.18s; }
  .pt-svc-card:nth-child(4) { transition-delay: 0.26s; }
  .pt-svc-card:hover {
    box-shadow: 0 8px 28px rgba(45,56,27,0.1);
    border-color: #d6ddd0;
  }

  /* GLP-1 highlight card */
  .pt-svc-card--highlight {
    border-color: var(--pt-coral);
    background: #fff9f8;
  }
  .pt-svc-card--highlight:hover { border-color: var(--pt-coral-dk); }

  .pt-svc-card__badge {
    display: inline-block;
    font-family: var(--pt-font-body);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #fff;
    background: var(--pt-coral);
    padding: 3px 8px;
    border-radius: 3px;
    align-self: flex-start;
  }

  .pt-svc-card__icon {
    width: 44px;
    height: 44px;
    background: #f0f4ed;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .pt-svc-card--highlight .pt-svc-card__icon {
    background: rgba(226,109,92,0.1);
  }
  .pt-svc-card__icon svg { display: block; }

  .pt-svc-card__title {
    font-family: var(--pt-font-body);
    font-size: 19px;
    font-weight: 800;
    color: var(--pt-green);
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  .pt-svc-card__desc {
    font-family: var(--pt-font-body);
    font-size: 14px;
    line-height: 1.7;
    color: var(--pt-muted);
    flex: 1;
  }
  .pt-svc-card__link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--pt-font-body);
    font-size: 13px;
    font-weight: 700;
    color: var(--pt-green-mid);
    text-decoration: none;
    padding-top: 8px;
    border-top: 1px solid #e8ebe4;
    transition: color 0.15s;
    margin-top: auto;
  }
  .pt-svc-card:hover .pt-svc-card__link { color: var(--pt-coral); }
  .pt-svc-card--highlight .pt-svc-card__link {
    color: var(--pt-coral);
    border-color: rgba(226,109,92,0.15);
  }

  @media (max-width: 900px) {
    .pt-services { padding: 70px 20px; }
    .pt-svc-grid { grid-template-columns: 1fr; }
  }
</style>

<section class="pt-services" id="pt-services">
  <div class="pt-services__inner">

    <div class="pt-services__header">
      <div class="pt-section-eyebrow">What We Treat</div>
      <h2 class="pt-section-heading">{{ section.settings.heading | default: 'Comprehensive Medical Weight Loss' }}</h2>
      <p class="pt-section-body">{{ section.settings.subheading | default: 'Every service at Pounds Transformation is physician-supervised and designed around your root cause — not a one-size-fits-all protocol.' }}</p>
    </div>

    <div class="pt-svc-grid">

      <a href="{{ section.settings.svc1_url | default: '/pages/services' }}" class="pt-svc-card" id="pt-svc-1">
        <div class="pt-svc-card__icon">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M11 2v4M11 16v4M4.22 4.22l2.83 2.83M14.95 14.95l2.83 2.83M2 11h4M16 11h4M4.22 17.78l2.83-2.83M14.95 7.05l2.83-2.83" stroke="#2f5233" stroke-width="1.6" stroke-linecap="round"/></svg>
        </div>
        <div class="pt-svc-card__title">{{ section.settings.svc1_title | default: 'Medical Weight Loss Programs' }}</div>
        <div class="pt-svc-card__desc">{{ section.settings.svc1_desc | default: 'Comprehensive evaluation including metabolic bloodwork, hormonal panels, and a personalized treatment plan supervised by board-certified physicians.' }}</div>
        <span class="pt-svc-card__link">Learn more <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2 5.5h7M6 3l3 2.5L6 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>

      <a href="{{ section.settings.svc2_url | default: '/pages/glp1-weight-loss-connecticut' }}" class="pt-svc-card pt-svc-card--highlight" id="pt-svc-2">
        <span class="pt-svc-card__badge">Now Available</span>
        <div class="pt-svc-card__icon">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M7 11h8M11 7v8" stroke="#e26d5c" stroke-width="1.8" stroke-linecap="round"/><circle cx="11" cy="11" r="8.5" stroke="#e26d5c" stroke-width="1.5"/></svg>
        </div>
        <div class="pt-svc-card__title">{{ section.settings.svc2_title | default: 'GLP-1 / Semaglutide Programs' }}</div>
        <div class="pt-svc-card__desc">{{ section.settings.svc2_desc | default: 'Medically supervised GLP-1 therapy (semaglutide, tirzepatide) administered by our ABOM Diplomate physicians — with full metabolic monitoring and support.' }}</div>
        <span class="pt-svc-card__link">Learn more <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2 5.5h7M6 3l3 2.5L6 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>

      <a href="{{ section.settings.svc3_url | default: '/pages/services' }}" class="pt-svc-card" id="pt-svc-3">
        <div class="pt-svc-card__icon">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M11 3C7.69 3 5 5.69 5 9c0 2.12 1.1 3.99 2.75 5.09L9 20h4l1.25-5.91C15.9 12.99 17 11.12 17 9c0-3.31-2.69-6-6-6z" stroke="#2f5233" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="pt-svc-card__title">{{ section.settings.svc3_title | default: 'Hormonal Weight Gain' }}</div>
        <div class="pt-svc-card__desc">{{ section.settings.svc3_desc | default: 'PCOS, menopause, thyroid dysfunction, and insulin resistance are among the most common — and most overlooked — drivers of weight gain in women.' }}</div>
        <span class="pt-svc-card__link">Learn more <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2 5.5h7M6 3l3 2.5L6 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>

      <a href="{{ section.settings.svc4_url | default: '/collections/all' }}" class="pt-svc-card" id="pt-svc-4">
        <div class="pt-svc-card__icon">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><rect x="6" y="3" width="10" height="16" rx="3" stroke="#2f5233" stroke-width="1.5"/><path d="M9 8h4M9 12h4" stroke="#2f5233" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
        <div class="pt-svc-card__title">{{ section.settings.svc4_title | default: 'Physician-Formulated Supplements' }}</div>
        <div class="pt-svc-card__desc">{{ section.settings.svc4_desc | default: 'Every supplement in our line is formulated by Dr. Cavo and clinically dosed. No fillers. Available online for patients near and far.' }}</div>
        <span class="pt-svc-card__link">Shop supplements <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2 5.5h7M6 3l3 2.5L6 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>

    </div>

  </div>
</section>

<script>
(function () {
  var cards = document.querySelectorAll('#pt-services .pt-svc-card');
  if (!('IntersectionObserver' in window)) {
    cards.forEach(function (el) { el.classList.add('visible'); });
    return;
  }
  var obs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
    });
  }, { threshold: 0.1 });
  cards.forEach(function (el) { obs.observe(el); });
}());
</script>

{% schema %}
{
  "name": "Homepage: Services",
  "tag": "div",
  "settings": [
    { "type": "text",     "id": "heading",    "label": "Heading",    "default": "Comprehensive Medical Weight Loss" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "text",     "id": "svc1_title", "label": "Service 1 title", "default": "Medical Weight Loss Programs" },
    { "type": "textarea","id": "svc1_desc",  "label": "Service 1 description" },
    { "type": "url",      "id": "svc1_url",   "label": "Service 1 URL" },
    { "type": "text",     "id": "svc2_title", "label": "Service 2 title", "default": "GLP-1 / Semaglutide Programs" },
    { "type": "textarea","id": "svc2_desc",  "label": "Service 2 description" },
    { "type": "url",      "id": "svc2_url",   "label": "Service 2 URL" },
    { "type": "text",     "id": "svc3_title", "label": "Service 3 title", "default": "Hormonal Weight Gain" },
    { "type": "textarea","id": "svc3_desc",  "label": "Service 3 description" },
    { "type": "url",      "id": "svc3_url",   "label": "Service 3 URL" },
    { "type": "text",     "id": "svc4_title", "label": "Service 4 title", "default": "Physician-Formulated Supplements" },
    { "type": "textarea","id": "svc4_desc",  "label": "Service 4 description" },
    { "type": "url",      "id": "svc4_url",   "label": "Service 4 URL" }
  ],
  "presets": [{ "name": "Homepage: Services" }]
}
{% endschema %}
