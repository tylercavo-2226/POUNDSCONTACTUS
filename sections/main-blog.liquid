<div style="max-width:1100px;margin:0 auto;padding:80px 32px;font-family:'Inter',sans-serif;">
  <h1 style="font-size:36px;font-weight:800;color:#2d381b;margin-bottom:40px;">{{ blog.title }}</h1>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:28px;">
    {%- for article in blog.articles -%}
      <a href="{{ article.url }}" style="background:#fff;border:1px solid #e8ebe4;border-radius:14px;overflow:hidden;text-decoration:none;">
        {%- if article.image -%}<img src="{{ article.image | img_url: '600x400', crop: 'center' }}" alt="{{ article.title }}" style="width:100%;aspect-ratio:3/2;object-fit:cover;">{%- endif -%}
        <div style="padding:22px 24px;">
          <div style="font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#e26d5c;margin-bottom:8px;">{{ article.published_at | date: '%B %d, %Y' }}</div>
          <div style="font-size:17px;font-weight:800;color:#2d381b;margin-bottom:10px;line-height:1.3;">{{ article.title }}</div>
          <div style="font-size:13px;color:#484947;line-height:1.6;">{{ article.excerpt | strip_html | truncate: 120 }}</div>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>
{% schema %}{ "name": "Blog", "tag": "div", "settings": [] }{% endschema %}
