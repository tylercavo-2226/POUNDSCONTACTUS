<div style="max-width:760px;margin:0 auto;padding:80px 32px;font-family:'Inter',sans-serif;">
  <div style="font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#e26d5c;margin-bottom:12px;">{{ article.published_at | date: '%B %d, %Y' }}</div>
  <h1 style="font-size:38px;font-weight:800;color:#2d381b;margin-bottom:24px;line-height:1.1;">{{ article.title }}</h1>
  {%- if article.image -%}<img src="{{ article.image | img_url: '1200x600', crop: 'center' }}" alt="{{ article.title }}" style="width:100%;border-radius:14px;margin-bottom:36px;">{%- endif -%}
  <div style="font-size:16px;line-height:1.8;color:#484947;">{{ article.content }}</div>
</div>
{% schema %}{ "name": "Article", "tag": "div", "settings": [] }{% endschema %}
