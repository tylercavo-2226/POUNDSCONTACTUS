{%- comment -%}
  sections/homepage-team.liquid
  Pounds Transformation — Team & Credentials Section
  Brings board certifications from sub-pages to homepage
{%- endcomment -%}

<style>
  .pt-team {
    background: var(--pt-green);
    padding: 100px var(--pt-px);
    color: #fff;
  }
  .pt-team__inner {
    max-width: var(--pt-max-w);
    margin: 0 auto;
  }
  .pt-team__header {
    text-align: center;
    max-width: 580px;
    margin: 0 auto 64px;
  }
  .pt-team__header .pt-section-eyebrow {
    color: var(--pt-amber);
  }
  .pt-team__header .pt-section-eyebrow::before {
    background: var(--pt-amber);
  }
  .pt-team__header .pt-section-heading {
    color: #fff;
  }
  .pt-team__header .pt-section-body {
    color: rgba(255,255,255,0.65);
  }

  .pt-team__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 48px;
  }

  .pt-team-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 36px 32px;
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .pt-team-card.visible { opacity: 1; transform: translateY(0); }
  .pt-team-card:nth-child(2) { transition-delay: 0.14s; }

  .pt-team-card__name {
    font-family: var(--pt-font-head);
    font-size: 20px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 4px;
    letter-spacing: -0.01em;
  }
  .pt-team-card__title {
    font-family: var(--pt-font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pt-amber);
    margin-bottom: 22px;
  }

  .pt-cred-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .pt-cred-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-family: var(--pt-font-body);
    font-size: 13px;
    line-height: 1.5;
    color: rgba(255,255,255,0.78);
  }
  .pt-cred-list__icon {
    width: 18px;
    height: 18px;
    background: rgba(255,222,169,0.2);
    border-radius: 50%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
  }
  .pt-cred-list__icon svg { display: block; }

  /* Partner badge */
  .pt-team__partner {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,222,169,0.3);
    border-radius: 10px;
    padding: 24px 32px;
    display: flex;
    align-items: center;
    gap: 20px;
    max-width: 680px;
    margin: 0 auto 48px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease 0.3s, transform 0.6s ease 0.3s;
  }
  .pt-team__partner.visible { opacity: 1; transform: translateY(0); }
  .pt-team__partner-icon {
    width: 48px;
    height: 48px;
    background: rgba(255,222,169,0.15);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 22px;
  }
  .pt-team__partner-body {}
  .pt-team__partner-label {
    font-family: var(--pt-font-body);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pt-amber);
    margin-bottom: 4px;
  }
  .pt-team__partner-text {
    font-family: var(--pt-font-body);
    font-size: 14px;
    line-height: 1.6;
    color: rgba(255,255,255,0.75);
  }
  .pt-team__partner-text strong {
    color: #fff;
  }

  .pt-team__cta {
    text-align: center;
  }
  .pt-link-arrow-lt {
    font-family: var(--pt-font-body);
    font-size: 14px;
    font-weight: 700;
    color: var(--pt-amber);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    border-bottom: 1.5px solid rgba(255,222,169,0.35);
    padding-bottom: 2px;
    transition: color 0.15s, border-color 0.15s;
  }
  .pt-link-arrow-lt:hover { color: #fff; border-color: rgba(255,255,255,0.4); }

  @media (max-width: 900px) {
    .pt-team          { padding: 70px 20px; }
    .pt-team__grid    { grid-template-columns: 1fr; }
    .pt-team__partner { flex-direction: column; text-align: center; }
  }
</style>

<section class="pt-team" id="pt-team">
  <div class="pt-team__inner">

    <div class="pt-team__header">
      <div class="pt-section-eyebrow" style="color:var(--pt-amber);justify-content:center;">Our Medical Team</div>
      <h2 class="pt-section-heading" style="color:#fff;">{{ section.settings.heading | default: 'Credentials That Exceed Virtually Every Competitor in Connecticut' }}</h2>
      <p class="pt-section-body" style="color:rgba(255,255,255,0.6);">{{ section.settings.subheading | default: 'Most weight loss clinics are run by nurse practitioners or general physicians. Ours are led by dual board-certified specialists with fellowship credentials in obesity medicine.' }}</p>
    </div>

    <div class="pt-team__grid">

      <div class="pt-team-card" id="pt-card-1">
        <div class="pt-team-card__name">Dr. Charles Cavo, D.O.</div>
        <div class="pt-team-card__title">Chief Medical Officer</div>
        <ul class="pt-cred-list">
          <li>
            <span class="pt-cred-list__icon">
              <svg width="9" height="9" viewBox="0 0 9 9" fill="none"><path d="M1.5 4.5l2 2 4-4" stroke="#ffdea9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            Board Certified in Bariatric Medicine
          </li>
          <li>
            <span class="pt-cred-list__icon">
              <svg width="9" height="9" viewBox="0 0 9 9" fill="none"><path d="M1.5 4.5l2 2 4-4" stroke="#ffdea9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            Board Certified in OB/GYN
          </li>
          <li>
            <span class="pt-cred-list__icon">
              <svg width="9" height="9" viewBox="0 0 9 9" fill="none"><path d="M1.5 4.5l2 2 4-4" stroke="#ffdea9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            ABOM Diplomate — American Board of Obesity Medicine
          </li>
          <li>
            <span class="pt-cred-list__icon">
              <svg width="9" height="9" viewBox="0 0 9 9" fill="none"><path d="M1.5 4.5l2 2 4-4" stroke="#ffdea9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            FACOG Fellow — American College of OB/GYN
          </li>
        </ul>
      </div>

      <div class="pt-team-card" id="pt-card-2">
        <div class="pt-team-card__name">Michelle Cavo, PA-C</div>
        <div class="pt-team-card__title">Founder &amp; Lead Provider</div>
        <ul class="pt-cred-list">
          <li>
            <span class="pt-cred-list__icon">
              <svg width="9" height="9" viewBox="0 0 9 9" fill="none"><path d="M1.5 4.5l2 2 4-4" stroke="#ffdea9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            Physician Assistant-Certified (PA-C)
          </li>
          <li>
            <span class="pt-cred-list__icon">
              <svg width="9" height="9" viewBox="0 0 9 9" fill="none"><path d="M1.5 4.5l2 2 4-4" stroke="#ffdea9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            Certified in Obesity Medicine
          </li>
          <li>
            <span class="pt-cred-list__icon">
              <svg width="9" height="9" viewBox="0 0 9 9" fill="none"><path d="M1.5 4.5l2 2 4-4" stroke="#ffdea9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            Master of Public Health (MPH)
          </li>
          <li>
            <span class="pt-cred-list__icon">
              <svg width="9" height="9" viewBox="0 0 9 9" fill="none"><path d="M1.5 4.5l2 2 4-4" stroke="#ffdea9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            Founded Pounds Transformation in 2013
          </li>
        </ul>
      </div>

    </div>

    <div class="pt-team__partner" id="pt-partner">
      <div class="pt-team__partner-icon">🏥</div>
      <div class="pt-team__partner-body">
        <div class="pt-team__partner-label">Institutional Referral Partner</div>
        <div class="pt-team__partner-text">
          <strong>Women's Health Connecticut</strong> refers patients directly to Pounds Transformation — peer physician endorsement from one of Connecticut's largest OB/GYN networks.
        </div>
      </div>
    </div>

    <div class="pt-team__cta">
      <a href="{{ section.settings.cta_url | default: '/pages/about-us' }}" class="pt-link-arrow-lt">
        {{ section.settings.cta_label | default: 'Meet Our Full Team' }}
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
          <path d="M2 6.5h9M8 3l4 3.5-4 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<script>
(function () {
  var els = [
    document.getElementById('pt-card-1'),
    document.getElementById('pt-card-2'),
    document.getElementById('pt-partner')
  ].filter(Boolean);
  if (!('IntersectionObserver' in window)) {
    els.forEach(function (el) { el.classList.add('visible'); });
    return;
  }
  var obs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
    });
  }, { threshold: 0.18 });
  els.forEach(function (el) { obs.observe(el); });
}());
</script>

{% schema %}
{
  "name": "Homepage: Team",
  "tag": "div",
  "settings": [
    { "type": "text",     "id": "heading",    "label": "Heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "text",     "id": "cta_label",  "label": "CTA text",  "default": "Meet Our Full Team" },
    { "type": "url",      "id": "cta_url",    "label": "CTA URL" }
  ],
  "presets": [{ "name": "Homepage: Team" }]
}
{% endschema %}
