<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }} — Coming Soon</title>
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;800&display=swap" rel="stylesheet">
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Inter',sans-serif;background:#2d381b;color:#fff;min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:40px 20px}
    h1{font-size:clamp(28px,4vw,48px);font-weight:800;letter-spacing:-0.02em;margin-bottom:16px}
    p{font-size:16px;color:rgba(255,255,255,0.7);margin-bottom:32px;line-height:1.6}
    .badge{display:inline-block;font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#e26d5c;background:rgba(226,109,92,.12);border:1px solid rgba(226,109,92,.3);padding:6px 14px;border-radius:20px;margin-bottom:24px}
    form{display:flex;gap:8px;max-width:400px;margin:0 auto;flex-wrap:wrap;justify-content:center}
    input{flex:1;min-width:200px;padding:13px 16px;border-radius:6px;border:none;font-family:inherit;font-size:14px;outline:none}
    button{background:#e26d5c;color:#fff;font-family:inherit;font-size:14px;font-weight:700;padding:13px 22px;border:none;border-radius:6px;cursor:pointer}
    button:hover{background:#c95b4b}
  </style>
</head>
<body>
  <div>
    <div class="badge">Pounds Transformation</div>
    <h1>Medical Weight Loss in Central CT</h1>
    <p>Our new site is launching soon. Enter the password to preview, or drop your email to be the first to know.</p>
    {{ content_for_layout }}
  </div>
</body>
</html>
